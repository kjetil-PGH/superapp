NEONOMICS_CLIENT_ID=your_client_id_here
NEONOMICS_CLIENT_SECRET=your_secret_id_here
NEONOMICS_BASE_URL=https://sandbox.neonomics.io
NEONOMICS_AUTH_URL=https://sandbox.neonomics.io/auth/realms/sandbox/protocol/openid-connect/token
NEONOMICS_REDIRECT_URL=http://localhost:5173/connect/callback
